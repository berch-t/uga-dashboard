# ---------------------------------------------------------------------------
# Environment configuration.
# Copy this file to `.env.local` for development:   cp env.example .env.local
# Every variable is OPTIONAL: the project runs with zero configuration.
# ---------------------------------------------------------------------------

# OpenAlex "polite pool": adding a contact e-mail routes requests to a faster,
# more reliable pool and is the etiquette requested by OpenAlex.
# https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_MAILTO=demo@uga-dashboard.fr

# OpenAlex institution identifier for Université Grenoble Alpes.
# Override to retarget the whole dashboard at another institution.
NEXT_PUBLIC_INSTITUTION_OPENALEX_ID=I899635006

# HAL structure acronym used to scope the HAL corpus.
HAL_STRUCT_ACRONYM=UGA

# Human-readable institution label shown in the UI.
NEXT_PUBLIC_INSTITUTION_NAME="Université Grenoble Alpes"
